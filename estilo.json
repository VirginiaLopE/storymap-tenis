{
  "version": 8,
  "name": "Mapa Base Limpio",
  "metadata": {"maputnik:renderer": "mlgljs"},
  "sources": {
    "openmaptiles": {
      "type": "vector",
      "url": "https://api.maptiler.com/tiles/v3/tiles.json?key=sGq3I5XV0ASFmUtS4VjC"
    }
  },
  "sprite": "https://api.maptiler.com/maps/basic-v2/sprite",
  "glyphs": "https://api.maptiler.com/fonts/{fontstack}/{range}.pbf?key=sGq3I5XV0ASFmUtS4VjC",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {"background-color": "#242424"}
    },
    {
      "id": "water",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "water",
      "paint": {"fill-color": "#1a1a1a"}
    },
    {
      "id": "countries",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "boundary",
      "filter": ["==", "admin_level", 2],
      "paint": {"line-color": "#3d3d3d", "line-width": 1}
    }
  ]
}